pipeline {
    agent {
        label 'ssh-agent'
    }

    stages {
        stage('Tests') {
            steps {
                sh '''
                    docker run --rm \
                        -v $(pwd)/cicd:/app \
                        -w /app \
                        python:3.11-slim \
                        sh -c "
                            pip install flask requests -q &&
                            python -m flask --app app run --host=0.0.0.0 > /tmp/flask.log 2>&1 &
                            python test_api.py
                            EXIT=$?
                            if [ $EXIT -ne 0 ]; then
                                echo '--- Logs Flask ---'
                                cat /tmp/flask.log
                            fi
                            exit $EXIT
                        "
                '''
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t registry:5000/water-app:latest cicd/'
                sh 'docker push registry:5000/water-app:latest'
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker rm -f water-app || true'
                sh 'docker run -d --name water-app -p 5000:5000 registry:5000/water-app:latest'
            }
        }
    }
}
